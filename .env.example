# ==============================================
# CONFIGURATION DE PRODUCTION - SYSTÈME SCOLAIRE
# ==============================================
# IMPORTANT: Copier ce fichier vers .env et remplir les valeurs
# NE JAMAIS commiter le fichier .env dans Git

# ============ Django Core ============
# Générer une clé secrète avec: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=votre-cle-secrete-ici-minimum-50-caracteres-aleatoires

# Mode debug: True pour développement, False pour production
DEBUG=False

# Hôtes autorisés (séparés par des virgules)
# En production: spécifier vos domaines réels
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com,www.votre-domaine.com

# ============ Base de données PostgreSQL ============
DB_NAME=gestion_scolaire
DB_USER=postgres
DB_PASSWORD=mot-de-passe-fort-postgresql
DB_HOST=localhost
DB_PORT=5432

# ============ Sécurité CSRF ============
# DANGER: Ne mettre à True que si vous savez ce que vous faites
CSRF_ALLOW_ALL_ORIGINS=False

# Origines de confiance pour CSRF (séparées par des virgules)
# Doit correspondre à vos domaines en HTTPS
CSRF_TRUSTED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com,https://localhost:8000

# ============ Sécurité CORS (pour API REST) ============
# DANGER: Ne mettre à True que si vous savez ce que vous faites
CORS_ALLOW_ALL_ORIGINS=False

# Origines CORS autorisées (séparées par des virgules)
CORS_ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# ============ Protection Brute-Force (AXES) ============
AXES_ENABLED=True
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME_MINUTES=30

# ============ Email SMTP ============
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
# Pour Gmail: utiliser un "App Password" (pas votre mot de passe principal)
# https://myaccount.google.com/apppasswords
EMAIL_HOST_PASSWORD=votre-app-password-16-caracteres
DEFAULT_FROM_EMAIL=Système Scolaire <noreply@votre-domaine.com>

# ============ Configuration Développement (optionnel) ============
# Pour le développement local uniquement
# DEBUG=True
# CSRF_ALLOW_ALL_ORIGINS=True
# CORS_ALLOW_ALL_ORIGINS=True

# ============ Sauvegarde Cloud (optionnel) ============
# BACKUP_AZURE_STORAGE_CONNECTION_STRING=votre-connection-string
# BACKUP_AZURE_CONTAINER_NAME=school-backups
