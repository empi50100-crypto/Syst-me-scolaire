# ==============================================
# CONFIGURATION DE PRODUCTION - SYSTÈME SCOLAIRE
# ==============================================
# IMPORTANT: Copier ce fichier vers .env et remplir les valeurs

# ============ Django ============
SECRET_KEY=generer-une-cle-secrete-avec-django-secret-key-generator
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com

# ============ Sécurité HTTPS ============
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# ============ CORS (pour API REST) ============
CORS_ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# ============ Base de données ============
# Pour SQLite (développement)
# DATABASE_URL=db.sqlite3

# Pour PostgreSQL (PRODUCTION RECOMMANDÉ)
# DATABASE_URL=postgres://user:password@localhost:5432/school_db

# ============ Email (optionnel) ============
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=votre-email@gmail.com
# EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
# DEFAULT_FROM_EMAIL=Système Scolaire <noreply@votre-domaine.com>

# ============ Sauvegarde Cloud (optionnel) ============
# BACKUP_AZURE_STORAGE_CONNECTION_STRING=votre-connection-string
# BACKUP_AZURE_CONTAINER_NAME=school-backups
